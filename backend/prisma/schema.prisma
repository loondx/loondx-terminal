// LOONDX Terminal — Prisma Schema
// Design principle: Only persist what is SLOW/EXPENSIVE to re-fetch.
// News, social, filings → Redis (ephemeral, 10-30 min TTL)
// Company fundamentals + AI analysis → PostgreSQL (persist)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Core Company Record ──────────────────────────────────────────────────────
model Stock {
  id          String    @id @default(cuid())
  ticker      String    @unique   // e.g. RELIANCE, TCS, INFY
  name        String              
  exchange    String    @default("NSE")
  lastUpdated DateTime  @updatedAt

  price         Float?
  change        Float?
  changePercent Float?
  volume        Float?     // Added missing volume

  marketCap    Float?
  roe          Float?
  debtToEquity Float?
  eps          Float?
  stockPE      Float?
  bookValue    Float?

  financials   Json?      // Quarterly tables (Headers/Rows)
  
  sectorId     String?
  sector       Sector?     @relation(fields: [sectorId], references: [id])
  
  aiInsights   AIInsight[]
  priceHistory PriceHistory[]
  earnings     EarningsRecord[]
}

// ─── Historical Data (for trend & volatility analysis) ─────────────────────
model PriceHistory {
  id        String   @id @default(cuid())
  stockId   String
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  @@unique([stockId, date])
}

// ─── Earnings Records (to detect surprises) ───────────────────────────────
model EarningsRecord {
  id         String   @id @default(cuid())
  stockId    String
  stock      Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  quarter    String   // Q3-2024
  actualEPS  Float
  estEPS     Float?
  surprise   Float?   // % surprise
  revenue    Float?
  netProfit  Float?
  reportDate DateTime
}

// ─── Sector & Relationships ──────────────────────────────────────────────────
model Sector {
  id           String  @id @default(cuid())
  name         String  @unique  // IT, Banking, Energy, etc.
  performance  Float?   // 24h sector movement
  volatility   Float?
  sentiment    String?  // BULLISH | BEARISH
  macroContext String? @db.Text
  stocks       Stock[]
  dependencies DependencyMap[] @relation("AffectedSector")
}

// ─── Event Impact System (e.g. Oil -> Airlines) ─────────────────────────────
model DependencyMap {
  id               String   @id @default(cuid())
  sourceType       String   // MACRO | SECTOR
  sourceName       String   // e.g. "Crude Oil"
  affectedSectorId String?
  affectedSector   Sector?  @relation("AffectedSector", fields: [affectedSectorId], references: [id])
  impactDirection  String   // NEGATIVE | POSITIVE
  description      String   // "High oil prices increase fuel parity costs for airlines"
}

// ─── AI Intelligence (Insight over Data) ──────────────────────────────────────
model AIInsight {
  id              String   @id @default(cuid())
  stockId         String
  stock           Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  
  summary         String   @db.Text
  recommendation  String?  // BUY | HOLD | SELL
  analysisType    String?  @default("DEEP_RESEARCH")
  
  // Structured Insight Scores (0-100)
  sentimentScore  Float?   
  riskScore       Float?
  valuationScore  Float?
  growthScore     Float?
  
  intrinsicValue  Float?
  impactChain     String?  @db.Text
  precomputedAt   DateTime @default(now())
  expiresAt       DateTime? // For job compatibility
}

// ─── Market Narrative (Daily context) ────────────────────────────────────────
model MarketSummary {
  id          String   @id @default(cuid())
  date        DateTime @unique @default(now())
  narrative   String   @db.Text // AI generated: "Nifty gained today because..."
  topThemes   String[]          // ["Banking Rally", "IT Weakness"]
  volatility  String?           // LOW | HIGH
}

// ─── Raw Macro Signals ──────────────────────────────────────────────────────
model MacroSignal {
  id          String   @id @default(cuid())
  name        String   // Oil Price, USD/INR, etc.
  value       Float
  unit        String?
  change      Float?
  impact      String?  @db.Text // JSON string of ripple effects
  lastUpdated DateTime @default(now())
}

// ─── Search Trends (Sentiment Engine) ───────────────────────────────────────
model GoogleTrend {
  id            String   @id @default(cuid())
  term          String   @unique
  score         Int
  isSpiking     Boolean  @default(false)
  lastUpdated   DateTime @default(now())
}
